@page "/login"
@inject AdminAuthService AdminAuth
@inject NavigationManager Navigation

<PageTitle>Login | Bedazzled Admin</PageTitle>

<div class="bg-watercolor min-vh-100 d-flex align-items-center justify-content-center">
    <div class="glass-card p-5 shadow-lg border-0" style="max-width: 400px; width: 100%;" data-aos="zoom-in">
        <div class="text-center mb-4">
            <img src="assets/logo.jpeg" alt="Logo" width="80" height="80" class="rounded-circle mb-3 shadow-sm border" style="object-fit:cover;" />
            <h2 class="brand-font fw-bold">Admin Login</h2>
            <p class="text-muted">Sign in with your Firebase admin account</p>
        </div>

        <div class="mb-4">
            <input type="email" class="form-control rounded-pill px-4 py-3 mb-3" placeholder="Email" @bind="email" @onkeyup="HandleKeyUp" />
            <input type="password" class="form-control rounded-pill px-4 py-3" placeholder="Password" @bind="password" @onkeyup="HandleKeyUp" />
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <p class="text-danger small mt-2 px-3">@errorMessage</p>
            }
        </div>

        <button class="btn custom-btn rounded-pill w-100 py-3 fs-5 floating-3d" @onclick="HandleLogin" disabled="@isLoading">
            @(isLoading ? "Authenticating..." : "Login")
        </button>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";
    private bool isLoading = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && await AdminAuth.HasValidSessionAsync())
        {
            Navigation.NavigateTo("/admin");
        }
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Please enter your email and password.";
            return;
        }

        isLoading = true;
        errorMessage = "";

        var loginError = await AdminAuth.LoginAsync(email, password);
        if (string.IsNullOrEmpty(loginError))
        {
            Navigation.NavigateTo("/admin");
        }
        else
        {
            errorMessage = loginError;
        }

        isLoading = false;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await HandleLogin();
        }
    }
}
