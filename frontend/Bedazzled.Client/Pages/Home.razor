@page "/"
@using Bedazzled.Client.Services
@inject IJSRuntime JSRuntime
@inject HttpClient Http
@inject ModalService ModalService

<PageTitle>Bedazzled Facepainting</PageTitle>

<div class="bg-watercolor pb-5">
    <!-- Hero Section -->
    <section class="container py-5" style="min-height: 85vh; display: flex; align-items: center;" id="about">
        <div class="row align-items-center w-100">
            <div class="col-lg-6 mb-5 mb-lg-0" data-aos="fade-right">
                <h1 class="display-3 fw-bold mb-3 brand-font text-gradient">Bringing Magic & Color to Your Event!</h1>
                <p class="lead text-muted mb-4 pe-md-5">
                    Welcome to <strong>Bedazzled Facepainting</strong>! We specialize in transforming little faces into fantastical creations, from roaring lions to sparkling fairies. Let us paint your day bright and beautiful!
                </p>
                <button @onclick="ModalService.ShowBookingModal" class="btn custom-btn rounded-pill px-5 py-3 fs-5 floating-3d d-inline-block border-0">Book Your Magic Now</button>
            </div>
            <div class="col-lg-6 text-center" data-aos="fade-left">
                <div class="hero-image-container">
                    <img src="assets/face1.jpeg" class="img-fluid rounded-circle hero-img-main floating-3d shadow-lg position-absolute" loading="lazy" alt="Face painting example 1"/>
                    <img src="assets/face2.jpeg" class="img-fluid rounded-circle hero-img-secondary floating-3d-slow shadow-lg position-absolute" loading="lazy" alt="Face painting example 2"/>
                    <img src="assets/face3.jpeg" class="img-fluid rounded-circle hero-img-tertiary floating-3d shadow-lg position-absolute" loading="lazy" alt="Face painting example 3"/>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section class="container py-5 mt-3" id="services">
        <div class="text-center mb-5" data-aos="fade-down">
            <h2 class="display-5 fw-bold brand-font">Our Magic Services</h2>
            <p class="text-muted lead">We bring color and joy to every occasion with professional artistry</p>
        </div>
        <div class="row g-4 justify-content-center">
            @foreach (var service in Services)
            {
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="@service.Delay">
                    <div class="glass-card p-4 text-center h-100 position-relative overflow-hidden d-flex flex-column">
                        <div class="mb-3 fs-1" style="color: @service.Color;"><i class="@service.Icon"></i></div>
                        <h3 class="fw-bold mb-3 brand-font">@((MarkupString)service.Title)</h3>
                        <p class="text-muted flex-grow-1">@service.Description</p>
                        <div class="mt-4">
                            <button @onclick="ModalService.ShowBookingModal" class="btn btn-outline-dark rounded-pill px-4">Enquire Now</button>
                        </div>
                    </div>
                </div>
            }
        </div>
        
        <div class="text-center mt-5 pt-3" data-aos="fade-up">
            <p class="text-muted italic mb-4">Don't see your event type here? Contact us and we'll tailor a package just for you!</p>
            <button @onclick="ModalService.ShowBookingModal" class="btn custom-btn rounded-pill px-5 py-3 fs-5 floating-3d d-inline-block border-0">Get a Custom Quote</button>
        </div>
    </section>

    <!-- My Creations -->
    <section class="container py-5 mt-5 text-center" id="creations">
        <h2 class="display-5 fw-bold mb-3 brand-font" data-aos="fade-down">My Creations</h2>
        <p class="text-muted mb-5 lead" data-aos="fade-up">Browse our gallery to see the enchanting transformations we've created for everyone!</p>
        
        <div class="row g-3">
            @for (int i = 4; i <= 13; i++)
            {
                var delay = (i % 3) * 100;
                <div class="col-6 col-md-4 col-lg-2" data-aos="zoom-in" data-aos-delay="@delay">
                    <div class="grid-item shadow-sm form-control-plaintext p-0" style="aspect-ratio: 1/1;">
                        <img src="assets/face@(i).jpeg" loading="lazy" alt="Creation" />
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Testimonials -->
    <section class="container py-5 mt-5" id="testimonials">
        <div class="text-center mb-5" data-aos="fade-down">
            <h2 class="display-5 fw-bold brand-font">What my happy customers had to say</h2>
        </div>
        
        @if (reviews == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading reviews...</span>
                </div>
            </div>
        }
        else if (!reviews.Any())
        {
            <div class="text-center py-5 text-muted">
                <p>No reviews yet. Be the first to tell us about your magic experience!</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var review in reviews)
                {
                    <div class="col-md-4" data-aos="flip-left" data-aos-delay="100">
                        <div class="testimonial-card border-top border-4 h-100 d-flex flex-column" style="border-color: @GetNextBorderColor() !important;">
                            <p class="text-muted fst-italic flex-grow-1">"@review.Content"</p>
                            <div class="text-warning mb-2">
                                @for (int i = 0; i < review.Rating; i++)
                                {
                                    <i class="fa-solid fa-star"></i>
                                }
                            </div>
                            <h6 class="fw-bold mb-0">@review.Author</h6>
                            @if (!string.IsNullOrEmpty(review.Subtitle))
                            {
                                <small class="text-muted">@review.Subtitle</small>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-5" data-aos="fade-up">
                <button @onclick="ModalService.ShowReviewModal" class="btn btn-outline-primary rounded-pill px-5 py-2 fw-bold">Leave a Review</button>
            </div>
        }
    </section>

    <!-- Contact & Social Media -->
    <section class="container py-5 my-5" id="contact" data-aos="fade-up">
        <div class="glass-card p-4 p-md-5 overflow-hidden position-relative border-0 shadow-lg" style="background: rgba(255,255,255,0.85);">
            <div class="position-absolute top-0 start-0 w-100 h-100 opacity-25" style="background-image: url('assets/background.jpeg'); background-size: cover; background-position: center; z-index: 0;"></div>
            
            <div class="row align-items-stretch justify-content-between position-relative" style="z-index: 1;">
                <div class="col-lg-5 text-dark mb-5 mb-lg-0 text-center text-lg-start d-flex flex-column justify-content-center">
                    <h2 class="display-6 fw-bold brand-font text-dark mb-4">Connect With Us</h2>
                    <p class="lead text-dark">Stay updated with our latest events and behind-the-scenes content. Join our community today!</p>
                    <div class="d-flex gap-3 justify-content-center justify-content-lg-start mt-4">
                        <a href="https://instagram.com/bedazzled" target="_blank" class="btn btn-dark rounded-circle social-icon floating-3d"><i class="fa-brands fa-instagram fs-4"></i></a>
                        <a href="https://facebook.com/bedazzled" target="_blank" class="btn btn-dark rounded-circle social-icon floating-3d" style="animation-delay: 0.2s;"><i class="fa-brands fa-facebook-f fs-4"></i></a>
                        <a href="https://tiktok.com/@@bedazzled" target="_blank" class="btn btn-dark rounded-circle social-icon floating-3d" style="animation-delay: 0.4s;"><i class="fa-brands fa-tiktok fs-4"></i></a>
                    </div>
                </div>
                
                <div class="col-lg-6">
                    <div class="bg-white rounded-4 p-4 p-md-5 shadow-sm h-100 d-flex flex-column text-start">
                        <div class="d-flex align-items-center mb-4">
                             <img src="assets/logo.jpeg" alt="Logo" width="50" height="50" class="rounded-circle me-3 border" style="object-fit:cover;" />
                             <div>
                                 <h5 class="fw-bold mb-0 brand-font">Bedazzled Facepainting</h5>
                                 <p class="text-muted small mb-0"><i class="fa-solid fa-phone me-1"></i> 082 618 2619</p>
                             </div>
                        </div>

                        <h4 class="fw-bold mb-3 brand-font">Send a Message</h4>
                        <EditForm Model="contactMessage" OnValidSubmit="HandleSubmit">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <InputText class="form-control rounded-pill bg-light border-0 px-3 py-2" placeholder="Your name" @bind-Value="contactMessage.Name" />
                            </div>
                            <div class="mb-3">
                                <InputText type="email" class="form-control rounded-pill bg-light border-0 px-3 py-2" placeholder="Your email" @bind-Value="contactMessage.Email" />
                            </div>
                            <div class="mb-3">
                                <InputText class="form-control rounded-pill bg-light border-0 px-3 py-2" placeholder="Subject" @bind-Value="contactMessage.Subject" />
                            </div>
                            <div class="mb-4">
                                <InputTextArea class="form-control rounded-4 bg-light border-0 px-3 py-2" rows="4" placeholder="Your message" @bind-Value="contactMessage.Message" />
                            </div>
                            <button type="submit" class="btn custom-btn rounded-pill w-100 py-3 mt-auto fs-5 border-0" disabled="@isSubmitting">
                                @(isSubmitting ? "Sending..." : "Submit Message")
                            </button>
                            
                            @if (!string.IsNullOrEmpty(statusMessage))
                            {
                                <div class="mt-3 alert alert-@(statusClass) rounded-pill text-center py-2 animate-fade-in">
                                    @statusMessage
                                </div>
                            }
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private ContactMessage contactMessage = new();
    private List<Review>? reviews;
    private bool isSubmitting = false;
    private string statusMessage = "";
    private string statusClass = "";
    private int colorIndex = 0;
    private string[] borderColors = { "#0dcaf0", "#ffc107", "#198754", "#dc3545", "#6f42c1" };

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            reviews = await Http.GetFromJsonAsync<List<Review>>("api/reviews");
            if (reviews == null || !reviews.Any())
            {
                await Http.PostAsync("api/reviews/seed", null);
                reviews = await Http.GetFromJsonAsync<List<Review>>("api/reviews");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            reviews = new List<Review>();
        }
    }

    private string GetNextBorderColor()
    {
        var color = borderColors[colorIndex % borderColors.Length];
        colorIndex++;
        return color;
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        statusMessage = "";
        
        try 
        {
            var response = await Http.PostAsJsonAsync("api/contact", contactMessage);
            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Message sent successfully!";
                statusClass = "success";
                contactMessage = new(); 
                StateHasChanged();
            }
            else
            {
                statusMessage = "Error sending message.";
                statusClass = "danger";
            }
        }
        catch (Exception)
        {
            statusMessage = "Connection error.";
            statusClass = "danger";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private List<ServiceItem> Services = new()
    {
        new ServiceItem { 
            Title = "Birthday Parties", 
            Description = "Transforming little faces into lions, fairies and superheroes for your special day!", 
            Icon = "fa-solid fa-cake-candles", 
            Color = "#ffb6c1", 
            Delay = 100 
        },
        new ServiceItem { 
            Title = "Holiday & Seasonal", 
            Description = "Themed face art for Halloween, Christmas, Easter and all seasonal celebrations.", 
            Icon = "fa-solid fa-snowflake", 
            Color = "#add8e6", 
            Delay = 200 
        },
        new ServiceItem { 
            Title = "Corporate Events", 
            Description = "Professional face art for family days, company picnics and product launches.", 
            Icon = "fa-solid fa-briefcase", 
            Color = "#ffb6c1", 
            Delay = 300 
        },
        new ServiceItem { 
            Title = "Festivals & Fairs", 
            Description = "High-quality, fast designs that sparkle and stand out in large crowds and fairs.", 
            Icon = "fa-solid fa-flag", 
            Color = "#add8e6", 
            Delay = 100 
        },
        new ServiceItem { 
            Title = "Weddings & <br/> Private Parties", 
            Description = "Elegant and whimsical designs to keep guests of all ages entertained at your celebration.", 
            Icon = "fa-solid fa-heart", 
            Color = "#ffb6c1", 
            Delay = 200 
        },
        new ServiceItem { 
            Title = "School & <br/> Community", 
            Description = "Bringing smiles and school spirit to fundraisers, sports days and community gatherings.", 
            Icon = "fa-solid fa-school", 
            Color = "#add8e6", 
            Delay = 300 
        },
        new ServiceItem { 
            Title = "Themed <br/> Photoshoots", 
            Description = "Artistic, high-detail transformations tailored perfectly for your creative vision.", 
            Icon = "fa-solid fa-camera", 
            Color = "#ffb6c1", 
            Delay = 100 
        },
        new ServiceItem { 
            Title = "In-Store <br/> Promotions", 
            Description = "Draw crowds and create memorable shopping experiences with live artistic painting.", 
            Icon = "fa-solid fa-shop", 
            Color = "#add8e6", 
            Delay = 200 
        },
        new ServiceItem { 
            Title = "Baby Showers", 
            Description = "Celebrate new arrivals with gentle, themed designs that add sweetness to the occasion.", 
            Icon = "fa-solid fa-baby", 
            Color = "#ffb6c1", 
            Delay = 300 
        },
        new ServiceItem { 
            Title = "Nursery Visits", 
            Description = "Specially designed sensory-friendly sessions for our youngest friends in a safe environment.", 
            Icon = "fa-solid fa-puzzle-piece", 
            Color = "#add8e6", 
            Delay = 400 
        }
    };

    public class ServiceItem
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
        public string Color { get; set; } = "";
        public int Delay { get; set; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initAOS");
        }
    }
}
