@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ModalService ModalService
@using Bedazzled.Client.Components
@using Bedazzled.Client.Services

<div class="page text-start">
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm px-4">
        <a class="navbar-brand d-flex align-items-center" href="/">
            <img src="assets/logo.jpeg" alt="Bedazzled Facepainting" height="40" class="me-2 rounded-circle shadow-sm" style="object-fit: cover;" />
            <span class="fw-bold" style="font-family: 'Outfit', sans-serif; color: #333;">Bedazzled Facepainting</span>
        </a>
        <button class="navbar-toggler d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="navbarContent">
            <ul class="navbar-nav mb-2 mb-lg-0 align-items-lg-center">
                <li class="nav-item">
                    <a class="nav-link text-dark fw-medium mx-2" href="/">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark fw-medium mx-2" href="/#about">About</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark fw-medium mx-2" href="/#services">Services</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark fw-medium mx-2" href="/#contact">Contact</a>
                </li>
                <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
                    <button class="btn custom-btn rounded-pill px-4 border-0" @onclick="ModalService.ShowBookingModal">Book Now</button>
                </li>
            </ul>
        </div>
    </nav>

    <BookingModal IsVisible="@ModalService.IsBookingModalVisible" OnClose="ModalService.HideBookingModal" />

    <main>
        @Body
    </main>

    <footer class="text-center py-4 text-dark mt-auto" style="background-color: #fce4ec;">
        <p class="mb-0 fw-medium">© 2026 Bedazzled Facepainting. All rights reserved.</p>
        <a href="/admin" class="text-muted small text-decoration-none mt-2 d-inline-block opacity-50 hover-opacity-100">Admin Dashboard</a>
    </footer>

    <!-- WhatsApp Floating Button -->
    <a href="https://wa.me/27826182619" target="_blank" class="whatsapp-btn shadow-lg" style="z-index: 2000;">
        <i class="fa-brands fa-whatsapp"></i>
    </a>
</div>

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
        ModalService.OnModalStateChanged += StateHasChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
        ModalService.OnModalStateChanged -= StateHasChanged;
    }
}
